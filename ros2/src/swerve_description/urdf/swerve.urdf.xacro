<?xml version="1.0"?>
<robot xmlns:xacro="http://www.ros.org/wiki/xacro" name="swerve">
  <xacro:arg name="use_mock_hardware" default="false" />

  <xacro:include filename="$(find swerve_description)/urdf/swerve_exported.urdf.xacro" />

  <link name="swerve_base_link" />

  <joint name="swerve_base_to_l1" type="fixed">
    <parent link="swerve_base_link" />
    <child link="L1" />
    <origin xyz="0 0 0" rpy="0 0 0" />
  </joint>


</robot>
